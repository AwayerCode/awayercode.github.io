---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href="/" underline={false}>
        <div class="font-semibold">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1">
        <Link href="/blog">
          blog
        </Link>
        <span>
          {`/`}
        </span>
        <a
          href="/rss.xml"
          class="text-black/50 underline decoration-black/15 underline-offset-4 transition-colors duration-300 ease-in-out hover:text-black dark:text-white/75 dark:decoration-white/30 dark:hover:text-white"
        >
          rss
        </a>
        <span>
          {`/`}
        </span>
        <Link href="https://github.com/AwayerCode" external>
          github
        </Link>
      </nav>
    </div>
  </Container>
</header>
